<h1>Products</h1>

<% @products.each do |product| %>
  <section>
    <h2><%= link_to product.title, product_path(product) %></h2>
    <p>Category: <%= product.category.name %></p>
    <p>Price: <%= product.price %></p>
    <p>Stock: <%= product.stock_quantity %></p>
    <p>Description: <%= product.description %></p>
  </section>
<% end %>
