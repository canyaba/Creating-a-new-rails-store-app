<% content_for :title, "Products" %>

<section class="products-page">
  <header class="page-header">
    <div>
      <p class="eyebrow">Simple Store</p>
      <h1>Products</h1>
      <p class="page-copy">Browse the catalog, narrow the list, and open any product for full details.</p>
    </div>
  </header>

  <section class="toolbar">
    <%= form_with url: products_path, method: :get, local: true, class: "filters-form" do |form| %>
      <div class="field-group field-group--search">
        <%= form.label :q, "Search by title" %>
        <%= form.search_field :q, value: params[:q], placeholder: "e.g. Lamp, Chair, Wallet" %>
      </div>

      <div class="field-group">
        <%= form.label :category_id, "Category" %>
        <%= form.select :category_id,
                        options_from_collection_for_select(@categories, :id, :name, params[:category_id]),
                        { include_blank: "All categories" } %>
      </div>

      <div class="field-group">
        <%= form.label :sort, "Sort by" %>
        <%= form.select :sort,
                        options_for_select(
                          [
                            [ "Title (A-Z)", "title_asc" ],
                            [ "Price (Low to High)", "price_asc" ],
                            [ "Price (High to Low)", "price_desc" ],
                            [ "Category", "category_asc" ]
                          ],
                          @current_sort
                        ) %>
      </div>

      <div class="toolbar-actions">
        <%= form.submit "Apply" %>
        <%= link_to "Clear", products_path, class: "button button--secondary" %>
      </div>
    <% end %>
  </section>

  <section class="results-summary">
    <p>Page <strong><%= @page %></strong> of <strong><%= @total_pages %></strong></p>
  </section>

  <% if @products.any? %>
    <div class="product-grid">
      <% @products.each do |product| %>
        <article class="product-card">
          <div class="product-card__header">
            <div>
              <p class="product-card__category"><%= product.category.name %></p>
              <h2><%= link_to product.title, product_path(product) %></h2>
            </div>
            <p class="product-card__price"><%= number_to_currency(product.price) %></p>
          </div>

          <p class="product-card__description"><%= truncate(product.description, length: 55) %></p>

          <dl class="product-meta">
            <div>
              <dt>Stock</dt>
              <dd><%= product.stock_quantity %></dd>
            </div>
            <div>
              <dt>Status</dt>
              <dd><span class="<%= stock_status_badge_class(product) %>"><%= product.stock_status %></span></dd>
            </div>
          </dl>
        </article>
      <% end %>
    </div>
  <% else %>
    <section class="empty-state">
      <h2>No products found</h2>
      <p>Try adjusting the search, category, or sort options.</p>
    </section>
  <% end %>

  <% if @total_pages > 1 %>
    <nav class="pagination" aria-label="Pagination">
      <% if @page > 1 %>
        <%= link_to "Previous", products_path(products_query_params(page: @page - 1)), class: "button button--secondary" %>
      <% end %>

      <div class="pagination__pages">
        <% (1..@total_pages).each do |page_number| %>
          <% if page_number == @page %>
            <span class="pagination__page pagination__page--current"><%= page_number %></span>
          <% else %>
            <%= link_to page_number, products_path(products_query_params(page: page_number)), class: "pagination__page" %>
          <% end %>
        <% end %>
      </div>

      <% if @page < @total_pages %>
        <%= link_to "Next", products_path(products_query_params(page: @page + 1)), class: "button button--secondary" %>
      <% end %>
    </nav>
  <% end %>
</section>
